{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/backup-subscribers",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/email-sequence",
      "schedule": "0 9 * * *"
    }
  ]
}
